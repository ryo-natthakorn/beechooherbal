---
// src/components/AwardsMarquee.astro
// Replaces a flat 12-icon grid with a continuous strip (see .marquee in global.css) —
// a long, same-shape list of award badges reads better as a slow ticker than a static
// wall. Zero JS: pure CSS animation, paused on hover/focus, real content only (no
// text labels under the logos per the "logo wall = logo only" rule).
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface AwardItem {
  img: ImageMetadata;
  alt: string;
}

interface Props {
  awards: AwardItem[];
}

const { awards } = Astro.props;
---

<div class="marquee">
  <div class="marquee-track">
    {awards.map((award) => (
      <Image
        src={award.img}
        alt={award.alt}
        width={100}
        height={100}
        class="h-20 w-20 shrink-0 rounded-full bg-white object-contain p-2 shadow-soft md:h-24 md:w-24"
      />
    ))}
    {awards.map((award) => (
      <Image
        src={award.img}
        alt=""
        aria-hidden="true"
        data-marquee-clone
        width={100}
        height={100}
        class="h-20 w-20 shrink-0 rounded-full bg-white object-contain p-2 shadow-soft md:h-24 md:w-24"
      />
    ))}
  </div>
</div>
