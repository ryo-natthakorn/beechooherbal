---
// src/components/LanguageSwitcher.astro
// Floating pill toggle, fixed to the right edge, vertically centred. Asks the
// same registry SEOHead uses ("what's my twin?") and links to it — no
// hardcoded URLs; pairs.ts is the single source of truth.
//
// Clicking a language sets the `beechoo_lang` cookie so the root-language
// middleware (middleware.ts) treats it as an EXPLICIT choice and stops
// auto-redirecting on "/". Without this, a Thai-browser visitor who clicks
// "EN" lands on "/" and the middleware bounces them straight back to
// /th/home/ — i.e. the toggle appears broken (Thai only). Explicit choice
// always wins over Accept-Language.
import { getPair } from "../i18n/pairs";

interface Props {
  lang: "en" | "th";
}
const { lang } = Astro.props;

const pair = getPair(Astro.url.pathname);

// An orphan page (no twin yet) falls back to the other language's homepage
// so the control is always usable rather than linking to a 404.
const enHref = pair?.en ?? "/";
const thHref = pair?.th ?? "/th/home/";

const base = "px-4 py-2 text-sm font-bold text-center transition-colors";
const active = "bg-brand-green text-white";
const idle = "text-brand-green hover:bg-brand-green/10";
---

<div class="fixed right-3 top-1/2 z-50 -translate-y-1/2">
  <nav
    aria-label="Language switcher"
    class="flex flex-col overflow-hidden rounded-full border border-brand-green bg-white shadow-lg"
  >
    <a
      href={enHref}
      data-setlang="en"
      aria-current={lang === "en" ? "page" : undefined}
      class:list={[base, lang === "en" ? active : idle]}>EN</a
    >
    <a
      href={thHref}
      data-setlang="th"
      aria-current={lang === "th" ? "page" : undefined}
      class:list={[base, lang === "th" ? active : idle]}>ไทย</a
    >
  </nav>
</div>

<script is:inline>
  document.querySelectorAll("[data-setlang]").forEach(function (el) {
    el.addEventListener("click", function () {
      document.cookie =
        "beechoo_lang=" +
        el.getAttribute("data-setlang") +
        ";path=/;max-age=31536000;samesite=lax";
    });
  });
</script>
