---
// src/components/LanguageSwitcher.astro
// Floating horizontal pill, fixed top-right BELOW the sticky header (top-20) so it
// never collides with the header's own controls, stays out of the right-thumb scroll
// sweep mid-viewport, and clears the mobile contact bar at the bottom. Targets are
// ≥44px (min-h-11) and the nav label is localized per page language.
//
// It asks the same registry SEOHead uses ("what's my twin?") and links to it — no
// hardcoded URLs; pairs.ts is the single source of truth.
//
// Clicking a language sets the `beechoo_lang` cookie so the root-language middleware
// (middleware.ts) treats it as an EXPLICIT choice and stops auto-redirecting on "/".
// Without this, a Thai-browser visitor who clicks "EN" lands on "/" and the middleware
// bounces them straight back to /th/home/ — i.e. the toggle appears broken (Thai
// only). Explicit choice always wins over Accept-Language.
import { getPair } from "../i18n/pairs";
import { UI } from "../i18n/ui";

interface Props {
  lang: "en" | "th";
}
const { lang } = Astro.props;
const ui = UI[lang];

const pair = getPair(Astro.url.pathname);

// An orphan page (no twin yet) falls back to the other language's homepage
// so the control is always usable rather than linking to a 404.
const enHref = pair?.en ?? "/";
const thHref = pair?.th ?? "/th/home/";

const base =
  "flex min-h-11 items-center px-4 text-sm font-bold transition-colors duration-200 focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand-green";
const active = "bg-brand-green text-white";
const idle = "text-brand-green hover:bg-brand-green/10";
---

<!-- z-scale: header/switcher/contact-bar all sit at z-30 (no stacking conflicts by placement). -->
<div class="fixed top-20 right-3 z-30">
  <nav
    aria-label={ui.misc.languageSwitcher}
    class="flex overflow-hidden rounded-full border border-brand-green/40 bg-white shadow-soft-lg"
  >
    <a
      href={enHref}
      data-setlang="en"
      lang="en"
      aria-current={lang === "en" ? "page" : undefined}
      class:list={[base, lang === "en" ? active : idle]}>EN</a
    >
    <a
      href={thHref}
      data-setlang="th"
      lang="th"
      aria-current={lang === "th" ? "page" : undefined}
      class:list={[base, lang === "th" ? active : idle]}>ไทย</a
    >
  </nav>
</div>

<script is:inline>
  document.querySelectorAll("[data-setlang]").forEach(function (el) {
    el.addEventListener("click", function () {
      document.cookie =
        "beechoo_lang=" +
        el.getAttribute("data-setlang") +
        ";path=/;max-age=31536000;samesite=lax";
    });
  });
</script>
