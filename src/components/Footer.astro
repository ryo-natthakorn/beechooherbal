---
// src/components/Footer.astro
// CTA set confirmed by Crispin (CLAUDE.md §2): Call + Facebook + LINE as the main buttons,
// plus YouTube and TikTok as on the current site. No online booking system.
import { Image } from "astro:assets";
import logoFull from "../assets/images/logo-full.png";
import HerbalStrokes from "./HerbalStrokes.astro";
import { UI } from "../i18n/ui";

interface Props {
  lang: "en" | "th";
}

const { lang } = Astro.props;
const ui = UI[lang];
---

<footer class="relative overflow-hidden bg-brand-green px-4 py-12 text-white md:px-8">
  <HerbalStrokes class="pointer-events-none absolute inset-0 h-full w-full text-white opacity-10" />
  <div class="relative mx-auto flex max-w-5xl flex-col items-center gap-6 text-center">
    <Image src={logoFull} alt="Bee Choo Origin" width={160} height={226} />
    <!-- Slogan is serif italic per brand guide; brand-serenity is the only on-green brand
         token that clears WCAG AA (4.55:1 — brand-earth fails at 4.14:1). -->
    <p class="font-serif text-lg italic text-brand-serenity">{ui.footer.tagline}</p>

    <div class="flex flex-wrap justify-center gap-3">
      <a
        href="tel:+66020726698"
        class="btn-tactile flex min-h-11 items-center rounded-full bg-brand-yellow px-6 font-bold text-brand-ink hover:bg-brand-yellow/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        {ui.cta.call}
      </a>
      <a
        href="https://www.facebook.com/beechooherbal/"
        target="_blank"
        rel="noopener"
        class="btn-tactile flex min-h-11 items-center rounded-full bg-white px-6 font-bold text-brand-green hover:bg-white/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        {ui.cta.facebook}
      </a>
      <a
        href="https://lin.ee/ll3injb"
        target="_blank"
        rel="noopener"
        class="btn-tactile flex min-h-11 items-center rounded-full bg-white px-6 font-bold text-brand-green hover:bg-white/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        {ui.cta.line}
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-2 text-sm">
      <a href="https://www.facebook.com/beechooherbal/" target="_blank" rel="noopener" class="flex min-h-11 items-center px-3 underline-offset-4 decoration-brand-yellow decoration-2 transition-colors duration-200 hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">{ui.footer.socialFacebook}</a>
      <a href="https://www.youtube.com/channel/UCx7bazL8Sco0j3LnVnbO3Lg/featured" target="_blank" rel="noopener" class="flex min-h-11 items-center px-3 underline-offset-4 decoration-brand-yellow decoration-2 transition-colors duration-200 hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">{ui.footer.socialYoutube}</a>
      <a href="https://tiktok.com/@beechooth" target="_blank" rel="noopener" class="flex min-h-11 items-center px-3 underline-offset-4 decoration-brand-yellow decoration-2 transition-colors duration-200 hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">{ui.footer.socialTiktok}</a>
    </div>
  </div>
</footer>
