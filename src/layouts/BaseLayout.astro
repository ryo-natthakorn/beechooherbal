---
// src/layouts/BaseLayout.astro
// Wraps every page. Owns <html lang>, head boilerplate, and delegates SEO.
// DOM order: skip link → header → content → footer → floating chrome. The
// LanguageSwitcher renders AFTER the page content so keyboard/screen-reader users
// reach the content first (it used to be the first two tab stops on every page);
// its fixed positioning makes DOM placement free.
import "../styles/global.css";
import SEOHead from "../components/SEOHead.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactBar from "../components/ContactBar.astro";
import { UI } from "../i18n/ui";

interface Props {
  title: string;
  description: string;
  lang: "en" | "th";
  image?: string;
  hreflangOverride?: { en?: string | null; th?: string | null };
}

const { title, description, lang, image, hreflangOverride } = Astro.props;
const ui = UI[lang];
// Fixes the live-site bug where Thai pages reported lang="en-US".
const htmlLang = lang === "th" ? "th" : "en";
const fontClass = lang === "th" ? "font-thai" : "font-sans";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead {title} {description} {lang} {image} {hreflangOverride} />
    <slot name="head" />
  </head>
  <!-- pb-14 reserves space for the mobile ContactBar (min-h-14) so it never covers content. -->
  <body class={`${fontClass} pb-14 md:pb-0`}>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-full focus:bg-brand-green focus:px-5 focus:py-3 focus:font-bold focus:text-white"
    >
      {ui.misc.skipToContent}
    </a>
    <Header {lang} />
    <slot />
    <Footer {lang} />
    <LanguageSwitcher {lang} />
    <ContactBar {lang} />
  </body>
</html>
