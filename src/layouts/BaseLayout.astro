---
// src/layouts/BaseLayout.astro
// Wraps every page. Owns <html lang>, head boilerplate, and delegates SEO.
import SEOHead from "../components/SEOHead.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  lang: "en" | "th";
  image?: string;
  hreflangOverride?: { en?: string | null; th?: string | null };
}

const { title, description, lang, image, hreflangOverride } = Astro.props;
// Fixes the live-site bug where Thai pages reported lang="en-US".
const htmlLang = lang === "th" ? "th" : "en";
const fontClass = lang === "th" ? "font-thai" : "font-sans";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead {title} {description} {lang} {image} {hreflangOverride} />
    <slot name="head" />
  </head>
  <body class={fontClass}>
    <LanguageSwitcher {lang} />
    <Header {lang} />
    <slot />
    <Footer {lang} />
  </body>
</html>
