---
// src/pages/index.astro
// Layout system: Harmony-Green drenched hero (brand-committed color strategy) over a
// white/Earth-tint band alternation, Soft UI elevation on cards, Lora serif headings
// (the guide's digital stand-in for print-only Minion Pro), leaf dividers on the two
// key sections only, zero-JS scroll reveals (see global.css).
// All copy is verbatim from the live site (SEO) — the two-tier H1 uses nested spans so
// the rendered hierarchy changes while the DOM text stays identical.
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import TreatmentCard from "../components/TreatmentCard.astro";
import YouTubeEmbed from "../components/YouTubeEmbed.astro";
import LeafDivider from "../components/LeafDivider.astro";
import HerbalStrokes from "../components/HerbalStrokes.astro";
import { TREATMENTS } from "../data/treatments";
import { UI } from "../i18n/ui";
import howItWorks from "../assets/images/how-it-works.jpg";
import priceList from "../assets/images/price-list.jpg";
import locationsMap from "../assets/images/locations-map.jpg";
import awardsBanner from "../assets/images/awards-banner.jpg";
import review1 from "../assets/images/reviews/review-1.jpg";
import review2 from "../assets/images/reviews/review-2.jpg";
import review3 from "../assets/images/reviews/review-3.jpg";
import review4 from "../assets/images/reviews/review-4.jpg";
import singaporeExcellenceAward from "../assets/images/awards/singapore-excellence-award.jpg";
import singaporeHeartland from "../assets/images/awards/singapore-heartland.jpg";
import singaporePrestigeWinner from "../assets/images/awards/singapore-prestige-winner.jpg";
import singaporePrestige from "../assets/images/awards/singapore-prestige.jpg";
import superHealthBrand from "../assets/images/awards/super-health-brand.jpg";
import theEntrepreneur from "../assets/images/awards/the-entrepreneur.jpg";
import goldenEagleAward from "../assets/images/awards/golden-eagle-award.jpg";
import promisingSme500 from "../assets/images/awards/promising-sme-500.jpg";
import readersChoice from "../assets/images/awards/readers-choice.jpg";
import serviceClass from "../assets/images/awards/service-class.jpg";
import sinChewBusiness from "../assets/images/awards/sin-chew-business.jpg";
import tapAwards from "../assets/images/awards/tap-awards-most-innovative.png";

const lang = "en" as const;
const ui = UI[lang];
const title = "Bee Choo Herbal - Herbal Hair & Scalp Treatment, Bangkok";
const description =
  "Award-winning 100% natural herbal hair and scalp treatment clinic in Bangkok, Thailand. Hair loss, oily scalp, dandruff, grey hair and more.";

const awards = [
  { img: singaporeExcellenceAward, alt: "Singapore Excellence Award" },
  { img: singaporeHeartland, alt: "Singapore Heartland Award" },
  { img: singaporePrestigeWinner, alt: "Singapore Prestige Award — Winner" },
  { img: singaporePrestige, alt: "Singapore Prestige Award" },
  { img: superHealthBrand, alt: "Super Health Brand Award" },
  { img: theEntrepreneur, alt: "The Entrepreneur Award" },
  { img: goldenEagleAward, alt: "Golden Eagle Award" },
  { img: promisingSme500, alt: "Promising SME 500 Award" },
  { img: readersChoice, alt: "Reader's Choice Award" },
  { img: serviceClass, alt: "Service Class Award" },
  { img: sinChewBusiness, alt: "Sin Chew Business Excellence Award" },
  { img: tapAwards, alt: "TAP Awards — Most Innovative Badge" },
];

// Alt text transcribed from the actual screenshots (they are branded Thai testimonial
// cards) — previously all four shared one identical alt, so screen-reader users got
// zero information from the page's key social proof.
const reviews = [
  { img: review1, alt: "Customer review: loved the herbal hair colouring — beautiful colour, lovely helpful staff, back for a second visit and planning to keep coming" },
  { img: review2, alt: "Customer review: oily scalp visibly improved after trying the treatment — scalp feels clean and healthy" },
  { img: review3, alt: "Customer review: scalp felt refreshed almost from the first session, first-class service with a relaxing massage from the herbal application through to the wash" },
  { img: review4, alt: "Customer review: itchy scalp, dandruff and hair loss all gone thanks to the shop's herbal treatment, with truly enjoyable service" },
];
---

<BaseLayout {title} {description} {lang}>
  <main id="main">

    <!-- Hero — drenched in Harmony Green (brand-committed strategy: the primary colour
         carries the surface), with the guide's hand-drawn stroke line work behind. -->
    <section class="relative overflow-hidden bg-brand-green py-14 text-center md:py-20">
      <HerbalStrokes class="pointer-events-none absolute inset-0 h-full w-full text-white opacity-10" />
      <div class="relative mx-auto max-w-6xl px-4 md:px-8">
        <h1 class="mx-auto max-w-4xl font-serif font-bold text-white">
          <span class="block text-3xl text-balance md:text-5xl md:leading-tight">100% Natural Herbal Hair Treatment,</span>
          <span class="mt-3 block text-lg font-normal text-white/90 md:text-2xl">Safe, Highly Effective, Proven, Award Winning Hair Salon Clinic</span>
        </h1>
        <p class="mt-5 text-xl font-bold text-brand-yellow md:text-2xl">
          BEST HAIR LOSS TREATMENT CLINIC IN BANGKOK, Thailand
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="tel:+66020726698" class="flex min-h-11 items-center rounded-full bg-white px-7 font-bold text-brand-green shadow-soft-lg transition-colors duration-200 hover:bg-white/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
            Call Us Today
          </a>
          <a href="https://www.facebook.com/beechooherbal/" target="_blank" rel="noopener" class="flex min-h-11 items-center rounded-full bg-brand-yellow px-7 font-bold text-brand-ink shadow-soft-lg transition-colors duration-200 hover:bg-brand-yellow/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
            Talk to us on Facebook!
          </a>
          <a href="https://lin.ee/ll3injb" target="_blank" rel="noopener" class="flex min-h-11 items-center rounded-full border border-white/60 px-7 font-bold text-white transition-colors duration-200 hover:bg-white/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
            Add us on LINE
          </a>
        </div>
        <div class="mt-10">
          <YouTubeEmbed id="c8x_e1zPvMY" title="Bee Choo Herbal hair treatment introduction" />
        </div>
      </div>
    </section>

    <!-- Trust intro -->
    <section class="py-12 md:py-16">
      <div class="reveal mx-auto max-w-prose px-4 md:px-8 text-brand-origin leading-relaxed">
        <p>
          Bee Choo Origin is the largest scalp/hair loss treatment clinic specialising in the
          treatment of hair loss, dandruff, oily itchy scalp and other hair issues. There are 21
          outlets in Singapore, 68 outlets in Malaysia with more than 170 outlets across Asia
          Pacific. The Group has expanded into Bangkok, and by end 2025, Bee Choo Thailand has 16
          outlets. Annually, we serve millions of happy customers with effective and proven
          results.
        </p>
        <p class="mt-4">
          A recognised household brand name, established since 2000, our founder Madam Cheah Bee
          Chew and her brand has won numerous accolades from Singapore Agencies. You may read more
          from two articles written by Business Times Singapore titled
          <a class="text-brand-green underline" target="_blank" rel="noopener" href="https://web.archive.org/web/20181020133432/http://www.businesstimes.com.sg/hub/bt-salutes-enterprise-2016/power-of-testimonies-drives-business-growth">
            "Power of testimonies drives business growth"
          </a>
          and
          <a class="text-brand-green underline" target="_blank" rel="noopener" href="https://web.archive.org/web/20181020133432/http://www.businesstimes.com.sg/hub-projects/ceo-conversations-2017/sincerity-before-profit">
            "Sincerity before profit"
          </a>.
        </p>
      </div>
    </section>

    <!-- Treatment cards -->
    <section class="bg-brand-earth/25 py-12 md:py-16">
      <div class="reveal mx-auto max-w-6xl px-4 md:px-8">
        <LeafDivider />
        <h2 class="mb-8 text-center font-serif text-2xl font-bold text-balance text-brand-green md:text-3xl">
          Hair Treatment in Bangkok, Thailand (7 Types)
        </h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {TREATMENTS.map((treatment, i) => <TreatmentCard {treatment} {lang} featured={i === 0} />)}
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-12 text-center md:py-16">
      <div class="reveal mx-auto max-w-6xl px-4 md:px-8">
        <h2 class="mb-6 font-serif text-2xl font-bold text-balance text-brand-green md:text-3xl">
          100% NATURAL HERBAL HAIR TREATMENT - HOW IT WORKS
        </h2>
        <Image src={howItWorks} alt="Bee Choo herbal hair treatment 4-step process: spray and massage tonic, apply herbal cream, steam for 45 minutes, rinse and condition" width={900} height={506} class="mx-auto rounded-xl shadow-soft" />
        <div class="mt-6">
          <YouTubeEmbed id="QOgcSx7_C7w" title="How Bee Choo herbal hair treatment works" />
        </div>
        <p class="mx-auto mt-6 max-w-2xl text-sm leading-relaxed text-brand-origin">
          3 colours to choose from -&gt; Copper / Colourless / Darken, for more information please
          see our FAQ. Disclaimer: Results may vary depending on various factors such as hair type,
          age, ethnicity, etc.
        </p>
      </div>
    </section>

    <!-- Reviews -->
    <section class="bg-brand-earth/25 py-12 text-center md:py-16">
      <div class="reveal mx-auto max-w-6xl px-4 md:px-8">
        <LeafDivider />
        <h2 class="mb-8 font-serif text-2xl font-bold text-balance text-brand-green md:text-3xl">
          REVIEWS ON BEECHOO HAIR TREATMENT
        </h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {reviews.map((review) => (
            <Image src={review.img} alt={review.alt} width={400} height={400} class="h-auto w-full rounded-xl shadow-soft" />
          ))}
        </div>
        <a href="/reviews-and-testimonials-of-bee-choo-origin-treatment/" class="mt-6 inline-flex min-h-11 items-center px-3 text-brand-green underline transition-colors duration-200 hover:text-brand-green/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-green">
          Read more reviews and testimonials &rarr;
        </a>
      </div>
    </section>

    <!-- Awards -->
    <section class="py-12 text-center md:py-16">
      <div class="reveal mx-auto max-w-6xl px-4 md:px-8">
        <h2 class="mb-3 font-serif text-2xl font-bold text-balance text-brand-green md:text-3xl">OUR AWARDS &amp; RECOGNITIONS</h2>
        <p class="mx-auto mb-8 max-w-2xl text-sm leading-relaxed text-brand-origin">
          Certified with TQCSI, Bee Choo Herbal Hair Treatment surpassed the stringent criteria of
          the ISO standards and demonstrates consistent ability to enhance customer satisfaction and
          assurance to deliver quality service, which enables Bee Choo to receive a number of
          awards in the Asia Pacific.
        </p>
        <div class="grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-6">
          {awards.map((award) => (
            <Image src={award.img} alt={award.alt} width={100} height={100} class="mx-auto h-24 w-24 rounded-full bg-white object-contain p-2 shadow-soft transition-transform duration-200 motion-safe:hover:scale-105" />
          ))}
        </div>
        <Image src={awardsBanner} alt="Bee Choo Origin awards and recognitions" width={800} height={240} class="mx-auto mt-10 h-auto w-full max-w-3xl rounded-xl shadow-soft" />
      </div>
    </section>

    <!-- Pricing -->
    <section class="bg-brand-earth/25 py-12 text-center md:py-16">
      <div class="reveal mx-auto max-w-6xl px-4 md:px-8">
        <h2 class="mb-6 font-serif text-2xl font-bold text-balance text-brand-green md:text-3xl">
          AFFORDABLE HAIR TREATMENT IN Bangkok, Thailand
        </h2>
        <Image src={priceList} alt="Bee Choo hair treatment price list: 800 to 1200 Baht depending on hair length, no hidden charges" width={700} height={990} class="mx-auto rounded-xl shadow-soft" />
        <p class="mx-auto mt-6 max-w-2xl text-sm leading-relaxed text-brand-origin">
          Our prices are based on your hair length between 800 Baht to 1200 Baht for à la carte
          herbal hair treatment. Strictly no hidden charges. You may choose to make upfront payment
          before treatment.
        </p>
      </div>
    </section>

    <!-- Locations -->
    <section class="py-12 text-center md:py-16">
      <div class="reveal mx-auto max-w-6xl px-4 md:px-8">
        <h2 class="mb-6 font-serif text-2xl font-bold text-balance text-brand-green md:text-3xl">BEE CHOO THAILAND LOCATIONS</h2>
        <a href="/locations/" class="inline-block focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-green">
          <Image src={locationsMap} alt="Map of Bee Choo Thailand outlet locations in Bangkok" width={900} height={600} class="mx-auto rounded-xl shadow-soft" />
        </a>
        <div>
          <a href="/locations/" class="mt-6 inline-flex min-h-11 items-center rounded-full bg-brand-green px-7 font-bold text-white shadow-soft transition-colors duration-200 hover:bg-brand-green/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-green">
            {ui.misc.viewLocations} &rarr;
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
